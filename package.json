{
  "name": "bookshop-aws",
  "version": "1.0.0",
  "description": "Professional bookshop e-commerce platform for AWS deployment",
  "main": "backend/src/server.js",
  "scripts": {
    "start": "node backend/src/server.js",
    "dev": "nodemon backend/src/server.js",
    "frontend": "cd frontend && npm start",
    "backend": "nodemon backend/src/server.js",
    "install-all": "npm install && cd frontend && npm install && cd ../backend && npm install",
    "build": "cd frontend && npm run build",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "bookshop",
    "e-commerce",
    "aws",
    "nodejs",
    "express"
  ],
  "author": "AWS Practitioner",
  "license": "MIT",
  "dependencies": {
    "concurrently": "^8.2.2"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  }
}